{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "relay",
  "version": "0.4.0",
  "identifier": "app.relay.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "relay",
        "center": true,
        "width": 1280,
        "height": 788,
        "minWidth": 960,
        "minHeight": 600,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["gstreamer1.0-plugins-good", "gstreamer1.0-pipewire | gstreamer1.0-pulseaudio"]
      },
      "rpm": {
        "depends": ["gstreamer1-plugins-good"]
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/frizzonje/relay/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1MzA0QzM4NDFEQTkzOEUKUldTT2s5cEJPRXd3UldIKzBybjgrbWdiakw5dkhhZE9CUmRhcFovS0xRU0lCMDFFcFgrL2lJOGkK"
    }
  }
}
