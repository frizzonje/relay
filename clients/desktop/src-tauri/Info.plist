<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Без этих строк WKWebView прячет navigator.mediaDevices целиком, и web-UI
       падает с «Видеозвонки недоступны». Текст видит пользователь в системном
       запросе доступа к микрофону/камере. Tauri мёржит этот файл в Info.plist. -->
  <key>NSMicrophoneUsageDescription</key>
  <string>relay использует микрофон для голосовых и видеозвонков.</string>
  <key>NSCameraUsageDescription</key>
  <string>relay использует камеру для видеозвонков.</string>
</dict>
</plist>
