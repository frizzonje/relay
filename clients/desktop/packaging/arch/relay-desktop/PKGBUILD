# Maintainer: relay contributors <https://github.com/frizzonje/relay>
#
# Source package: builds the Tauri shell from the tagged sources with the
# system Rust toolchain. The frontend is the tiny static server-picker in
# clients/desktop/src (embedded into the binary at compile time) plus the
# remote web UI loaded at runtime — so there is no Node/pnpm build step here,
# just `cargo build`. We do the packaging ourselves instead of letting
# tauri-bundler emit a .deb/AppImage, which is the idiomatic makepkg way.

pkgname=relay-desktop
pkgver=0.3.7
pkgrel=1
pkgdesc="relay desktop client — native Tauri shell over the relay web app"
arch=('x86_64' 'aarch64')
url="https://github.com/frizzonje/relay"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator' 'hicolor-icon-theme')
makedepends=('rust' 'git' 'pkgconf' 'librsvg' 'libxdo')
provides=('relay-desktop')
conflicts=('relay-desktop-bin')
# LTO is already configured in the release profile (Cargo.toml); don't let
# makepkg inject its own conflicting LTO flags.
options=('!lto')
source=("git+${url}.git#tag=desktop-v${pkgver}")
sha256sums=('SKIP')

prepare() {
  cd "${srcdir}/relay/clients/desktop/src-tauri"
  export RUSTUP_TOOLCHAIN=stable
  # Fetch crates up front so build() can run fully offline (--frozen).
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "${srcdir}/relay/clients/desktop/src-tauri"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --release --frozen
}

package() {
  cd "${srcdir}/relay/clients/desktop"
  local _bin="src-tauri/target/release/relay-desktop"

  install -Dm755 "${_bin}" "${pkgdir}/usr/bin/relay-desktop"
  install -Dm644 "${srcdir}/relay/LICENSE" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Desktop entry (mirrors the fields tauri-bundler writes into the .deb).
  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/relay.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=relay
Comment=relay desktop — native shell over the relay web client
Exec=relay-desktop
Icon=relay
Terminal=false
Categories=Network;InstantMessaging;AudioVideo;
StartupWMClass=relay
EOF

  # Icons: hicolor raster set + scalable master.
  local _s
  for _s in 32 64 128; do
    install -Dm644 "src-tauri/icons/${_s}x${_s}.png" \
      "${pkgdir}/usr/share/icons/hicolor/${_s}x${_s}/apps/relay.png"
  done
  install -Dm644 "src-tauri/icons/128x128@2x.png" \
    "${pkgdir}/usr/share/icons/hicolor/256x256/apps/relay.png"
  install -Dm644 "src-tauri/icons/icon.png" \
    "${pkgdir}/usr/share/icons/hicolor/512x512/apps/relay.png"
  install -Dm644 "src-tauri/icons/icon.svg" \
    "${pkgdir}/usr/share/icons/hicolor/scalable/apps/relay.svg"
}
