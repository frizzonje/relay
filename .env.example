# Скопируйте в .env и заполните: cp .env.example .env
# .env в .gitignore — реальные секреты не коммитятся.

# ─── Доступ ───────────────────────────────────────────────────────────────────
# Пароль-пропуск. Пока не введён — не отдаётся ни страница, ни файл, ни socket.io.
# Пусто → сайт открыт всем (только для дева). Нужен ОДИНАКОВЫЙ для api и web.
# Смена пароля мгновенно отзывает все выданные куки relay_pass.
SITE_PASSWORD=

# ─── Сервер / TLS ─────────────────────────────────────────────────────────────
# Домен (или LAN-IP) для Caddy. localhost → самоподписанный внутренний CA.
# Реальный домен → автоматический сертификат Let's Encrypt.
DOMAIN=localhost

# Хост для ICE-конфига и realm coturn. Для прода = реальный публичный IP/домен.
SERVER_HOST=localhost

# Порт NestJS-приложения внутри контейнера.
PORT=3000

# ─── WebRTC: STUN / TURN ──────────────────────────────────────────────────────
# STUN через запятую. Пусто → свой coturn (stun:SERVER_HOST:3478, если профиль
# turn активен) + встроенные Google STUN как резерв.
# STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN нужен для звонков между строгими NAT (мобильный интернет, CGNAT).
# coturn встроен в docker-compose (профиль turn): docker compose --profile turn up.
# Достаточно задать TURN_CREDENTIAL — TURN_URLS соберётся из SERVER_HOST (UDP+TCP
# на 3478 + TURN over TLS на 5349, серт берётся из тома Caddy автоматически).
# На фаерволе откройте: 3478/udp, 3478/tcp, 5349/tcp, 49160-49200/udp.
TURN_USERNAME=webrtc
TURN_CREDENTIAL=

# Машина за 1:1-NAT (AWS/GCP/Yandex Cloud) — публичный IP для relay-кандидатов:
# TURN_EXTERNAL_IP=203.0.113.7

# Переопределить TURN_URLS вручную (приоритет над авто-сборкой):
# TURN_URLS=turn:your-server-ip:3478?transport=udp,turns:your-server-ip:5349?transport=tcp

# ─── Медиасервер (SFU) ────────────────────────────────────────────────────────
# Нужен для звонков на 4+ человек с видео: каждый шлёт своё видео один раз на
# сервер, а не всем подряд. Без него всё работает на p2p (mesh) — просто с
# потолком в 2–3 видео. Поднимается профилем: docker compose --profile sfu up.
#
# Общий ключ подписи пропусков (api выдаёт — sfu проверяет). Пусто → режим SFU
# в интерфейсе выключен. Сгенерировать: openssl rand -hex 32
SFU_SECRET=

# На фаерволе откройте диапазон RTC-портов (UDP и TCP):
# SFU_RTC_MIN_PORT=40000
# SFU_RTC_MAX_PORT=40100

# Машина за 1:1-NAT — публичный IP для ICE-кандидатов медиасервера.
# По умолчанию берётся TURN_EXTERNAL_IP (те же грабли, тот же адрес).
# SFU_ANNOUNCED_IP=203.0.113.7
